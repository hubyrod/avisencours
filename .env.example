# Required — ODS-style search API endpoint and dataset id.
PORTAL_API_URL=
PORTAL_DATASET=

MAX_PAGES=10

# Default classifier: hybrid (regex hard rules + Mistral semantic judgement).
# Requires MISTRAL_API_KEY. Falls back to regex if the key is missing.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
# Override mode if needed: hybrid | llm | regex
# CLASSIFIER=hybrid
